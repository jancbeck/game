    "worth_nothing": {
      "speaker": "Marda, Camp Leader",
      "text": "They dig anyway. Just deeper, and for less. Ask the chained man by the east posts — the Overseer judged him surplus. Prove yourself before someone does your arithmetic for you. Come back when you've done something the camp can chew on.",
      "options": [
        {
          "text": "Understood.",
          "effects": [],
          "next": "start"
        }
      ]
    },
    "accepted": {
      "speaker": "Marda, Camp Leader",
      "text": "Good. You're camp now — which means the Overseer knows your name by sundown. One more thing: the chained man. His judgement comes tomorrow. What you do about that is your own ledger.",
      "options": [
        {
          "text": "I'll look into it.",
          "effects": [],
          "next": ""
        }
      ]
    }
